# Telegram demo bot (получить у @BotFather)
BOT_TOKEN=your_demo_bot_token_here
BOT_USERNAME=PayTutorDemoBot

# Ваш Telegram user ID — @userinfobot /start (см. docs/DEMO_LAPTOP_SETUP.md §2)
ADMIN_CHAT_ID=123456789

# ID канала (начинается с -100) — @RawDataBot или php scripts/get_channel_id.php
CHANNEL_ID=-1001234567890

# Публичный URL backend (без слэша в конце)
# Вариант A (docroot = public/): https://demo-api.pay-tutor.ecomdev.uz
# Вариант B (docroot = репозиторий): https://demo-api.pay-tutor.ecomdev.uz/public
PUBLIC_BASE_URL=https://demo-api.pay-tutor.ecomdev.uz/public

# FreedomPay mock (demo)
MERCHANT_ID=TEST_MERCHANT
SECRET_KEY=test_secret

# Demo-режим: расширенные команды /demo, /reset, приветствие demo-стенда
DEMO_MODE=1

# Ссылки для сообщений бота
SITE_URL=https://pay-tutor.ecomdev.uz
SUPPORT_USERNAME=SupportUsername
TEACHER_USERNAME=TeacherUsername

# SQLite (опционально, по умолчанию data/database.sqlite)
# DATABASE_DSN=sqlite:path/to/database.sqlite

# Локальный URL health-check (OSPanel, вариант B)
LOCAL_HEALTH_URL=http://pay-tutor-uz/public/health.php
